# GitHub Pages Deployment Configuration
# Copy this file to .env.local and fill in your values

# Base path for GitHub Pages subdirectory (leave empty for root)
VITE_BASE_PATH=/quickinfer/

# jsDelivr CDN base URL for your GitHub Releases
# Format: https://cdn.jsdelivr.net/gh/{user}/{repo}@{tag}/
VITE_CDN_BASE=https://cdn.jsdelivr.net/gh/YOUR_USER/quickinfer@v1.0.0/

# Model files in your GitHub Release (must be .onnx files)
# Size is optional, used for display only
VITE_MODELS=[{"name":"yolov8n.onnx","path":"/models/yolov8n.onnx","size":"~6MB"},{"name":"yolov8s.onnx","path":"/models/yolov8s.onnx","size":"~12MB"}]