# GitHub Pages Deployment Configuration
# Copy this file to .env.local and fill in your values

# Base path for GitHub Pages subdirectory (leave empty for root)
VITE_BASE_PATH=/quickinfer/

# GitHub repository and release tag for model downloads
VITE_GITHUB_REPO=ckfanzhe/quickinfer
VITE_RELEASE_TAG=v1.0.0

# Model files in your GitHub Release (must be .onnx files)
VITE_MODELS=[{"name":"yolov8s.onnx","size":"~43MB"},{"name":"yolov8m.onnx","size":"~99MB"}]